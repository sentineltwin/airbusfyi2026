# ═══════════════════════════════════════════════════════════════
# SentinelTwin — Environment Configuration
# Copy to .env and fill in production values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_NAME=SentinelTwin
VERSION=4.2.1
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Security (CHANGE IN PRODUCTION) ───────────────────────────
SECRET_KEY=REPLACE_WITH_CRYPTOGRAPHICALLY_SECURE_256BIT_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── TLS ────────────────────────────────────────────────────────
SSL_ENABLED=false
SSL_KEYFILE=
SSL_CERTFILE=

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentineltwin:sentinel_secure_pw@localhost:5432/sentineltwin
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://:sentinel_redis_pw@localhost:6379/0
REDIS_MAX_CONNECTIONS=100

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=sentineltwin.telemetry
KAFKA_ANOMALY_TOPIC=sentineltwin.anomalies
KAFKA_ECAM_TOPIC=sentineltwin.ecam
KAFKA_AUDIT_TOPIC=sentineltwin.audit

# ── Sensor Engine ──────────────────────────────────────────────
SENSOR_COUNT=8192
SENSOR_SAMPLE_RATE_HZ=20.0
SENSOR_BATCH_SIZE=512
SENSOR_WORKER_COUNT=16
STALE_PACKET_THRESHOLD_SEC=5.0
REPLAY_WINDOW_SEC=30.0

# ── AI Engine ─────────────────────────────────────────────────
AI_MODEL_PATH=./models/autoencoder_v2.4.pkl
AI_ANOMALY_THRESHOLD=0.15
AI_INFERENCE_BATCH_SIZE=256
AI_RETRAIN_INTERVAL_HOURS=24
AI_LATENT_DIM=32

# ── Hash Chain ────────────────────────────────────────────────
HASH_ALGORITHM=SHA-256
HASH_CHAIN_PERSIST_INTERVAL=10
HASH_ARCHIVE_RETENTION_DAYS=2555

# ── X-Plane Simulator ─────────────────────────────────────────
XPLANE_HOST=127.0.0.1
XPLANE_PORT=49000
XPLANE_RECV_PORT=49001

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SEC=300

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/sentineltwin.log
LOG_RETENTION_DAYS=90

# ── Monitoring ────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ── Compliance ────────────────────────────────────────────────
COMPLIANCE_DO326A=true
COMPLIANCE_ED202A=true
COMPLIANCE_EASA_AMC_20_42=true
COMPLIANCE_ARINC_429=true
COMPLIANCE_ARINC_664=true
